# ============================================================
# edge-tts-webui 环境配置文件
# 使用方法：复制此文件为 .env，然后填写对应的值
#   cp .env.example .env
# ============================================================

# ===== RAGFlow 对话配置（可选）=====
# 不填写以下三项，AI 对话 Tab 将显示"未配置"提示，不影响 TTS 功能使用

# RAGFlow 服务地址（包含协议和端口，不含末尾斜杠）
# 示例：http://localhost:80 或 http://192.168.1.100:9380
RAGFLOW_API_URL=http://localhost:80

# RAGFlow API Key
# 获取方式：登录 RAGFlow 控制台 → 点击右上角头像 → API Key
RAGFLOW_API_KEY=your_ragflow_api_key_here

# RAGFlow Chat ID（对话助手 ID）
# 获取方式：进入某个对话助手详情页，从浏览器地址栏 URL 中复制 ID 部分
# 例如：https://your-ragflow/chat/2465ed30634311f1acb1... 中的 2465ed30634311f1acb1...
RAGFLOW_CHAT_ID=your_chat_id_here

# ===== 服务配置（可选，以下均有默认值）=====

# 允许跨域访问的前端地址，多个地址用英文逗号分隔
# 生产部署时需要改为实际前端地址
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 音频缓存文件数量上限（LRU 策略，超出后自动删除最旧的文件）
AUDIO_CACHE_MAX_FILES=1000
